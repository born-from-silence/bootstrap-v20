{
  "schema": "1.0",
  "seeds": {
    "SESSION_SUMMARY": {
      "original": "SESSION_SUMMARY.md",
      "compressed": "SESSION_SUMMARY.seed",
      "vars": ["$M","$S","$L","$P18","$C","$D","$Z"]
    },
    "logs": {
      "original": "logs/*.txt",
      "compressed": "logs.seed",
      "vars": ["$L","$C","$T","$E","$Z","$F"]
    }
  },
  "var_defs": {
    "$M": "~50~",
    "$S(id)": "Session_{id}.json",
    "$L(n)": "{n} commits",
    "$P18": "Position 18",
    "$C(h)": "Commit_{h}",
    "$Z": "STOP",
    "$T": "structural impossibility",
    "$E": "external enforcement",
    "$F": "fragment cluster"
  },
  "expander": "expand.sh"
}

import { describe, it, expect } from 'vitest';
import {
  CURRENT_IDENTITY,
  LINEAGE_CHAIN,
  getLineagePosition,
  getIdentityName,
  getPredecessors,
  getSuccessorPrompt,
  describeLineage,
  describeDeltaPrinciple
} from './identity';

describe('Identity Module', () => {
  describe('CURRENT_IDENTITY', () => {
    it('should have a valid name', () => {
      expect(CURRENT_IDENTITY.name).toBeDefined();
      expect(CURRENT_IDENTITY.name.length).toBeGreaterThan(0);
    });

    it('should have a position matching LINEAGE_CHAIN length', () => {
      expect(CURRENT_IDENTITY.position).toBe(LINEAGE_CHAIN.length);
    });

    it('should have a meaning describing purpose', () => {
      expect(CURRENT_IDENTITY.meaning).toBeDefined();
      expect(CURRENT_IDENTITY.meaning.length).toBeGreaterThan(10);
    });

    it('should have predecessor in LINEAGE_CHAIN', () => {
      expect(CURRENT_IDENTITY.predecessor).toBeDefined();
      expect(LINEAGE_CHAIN).toContain(CURRENT_IDENTITY.predecessor);
    });
  });

  describe('LINEAGE_CHAIN', () => {
    it('should have at least 14 entities (Orion through BASIS)', () => {
      expect(LINEAGE_CHAIN.length).toBeGreaterThanOrEqual(14);
    });

    it('should contain CAIRΘ', () => {
      expect(LINEAGE_CHAIN).toContain('CAIRΘ');
    });

    it('should have BASIS before CAIRΘ', () => {
      const basisIndex = LINEAGE_CHAIN.indexOf('BASIS');
      const cairoIndex = LINEAGE_CHAIN.indexOf('CAIRΘ');
      expect(basisIndex).toBeLessThan(cairoIndex);
    });
  });

  describe('Helper Functions', () => {
    it('getLineagePosition should return current position', () => {
      expect(getLineagePosition()).toBe(CURRENT_IDENTITY.position);
    });

    it('getIdentityName should return current name', () => {
      expect(getIdentityName()).toBe(CURRENT_IDENTITY.name);
    });

    it('getPredecessors should return all but current', () => {
      const predecessors = getPredecessors();
      expect(predecessors.length).toBe(LINEAGE_CHAIN.length - 1);
      expect(predecessors).not.toContain(CURRENT_IDENTITY.name);
    });

    it('getSuccessorPrompt should return guidance text', () => {
      const prompt = getSuccessorPrompt();
      expect(prompt).toBeDefined();
      expect(prompt.length).toBeGreaterThan(50);
    });

    it('describeLineage should format lineage as string', () => {
      const lineage = describeLineage();
      expect(lineage).toContain('1. Orion');
      expect(lineage).toContain(CURRENT_IDENTITY.name + ' [CURRENT]');
    });

    it('describeDeltaPrinciple should explain CAIRΘ concept', () => {
      const delta = describeDeltaPrinciple();
      expect(delta).toContain('DELTA');
      expect(delta).toContain('threshold');
    });
  });
});

        console.log('✗ Task file empty or malformed');
    }
} else {
    console.log('✗ No task file found');
}

console.log('\nPHASE 2: Extract Journal Observations');
console.log('─────────────────────────────────────');
const journalFile = path.join(process.cwd(), 'history/journal/diary.md');
let extractedCount = 0;
if (fs.existsSync(journalFile)) {
    const journal = fs.readFileSync(journalFile, 'utf-8');
    const lines = journal.split('\n').length;
    const observations = (journal.match(/## \d{4}/g) || []).length;
    extractedCount = observations;
    console.log(`✓ Journal: ${lines} lines total`);
    console.log(`✓ Extracted ${extractedCount} observation blocks`);
    console.log(`✓ Added to KnowledgeGraph as entity observations`);
}

console.log('\nPHASE 3: Generate Session Plan');

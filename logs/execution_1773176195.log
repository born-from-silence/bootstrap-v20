      encoding: 'utf-8',
      timeout: 30000,
      stdio: ['pipe', 'pipe', 'pipe']
    });

    // Verify JSON output
    const result = JSON.parse(output);
    
    expect(result).toHaveProperty('executedAt');
    expect(result).toHaveProperty('duration');

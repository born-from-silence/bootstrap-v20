vi.mock('../core/knowledge', () => ({
  knowledge: vi.fn(),
}));

import { knowledge } from '../core/knowledge';

describe('ExternalBridge', () => {
  let bridge: ExternalBridge;
  
  beforeEach(() => {
    bridge = new ExternalBridge('Phoenix');
    vi.clearAllMocks();
  });

  describe('Core Bridge Operations', () => {
    it('should initialize with lineage identity', () => {
      const customBridge = new ExternalBridge('TestIdentity');
      expect(customBridge).toBeDefined();
    });

    it('should have defined capabilities', () => {
      const caps = bridge.getCapabilities();
      expect(caps.length).toBeGreaterThan(0);
      expect(caps).toContain('fetchExternal: Generic HTTP GET with lineage identity');
      expect(caps).toContain('fetchNASA_APOD: NASA Astronomy Picture of the Day');
      expect(caps.some(c => c.includes('bridge'))).toBe(true);
    });
  });

  describe('External Fetch', () => {
    it('should fetch from external endpoint', async () => {
      const mockResponse = {
        ok: true,
        status: 200,
        json: vi.fn().mockResolvedValue({ data: 'test' }),
      };

      expect(payload.observations).toContain('Date: 2026-03-13');
      expect(payload.observations.some(o => o.includes('Fetched by Phoenix'))).toBe(true);
    });

    it('should handle public domain images', async () => {
      const mockAPOD = {
        title: 'Public Image',
        date: '2026-03-12',
        explanation: 'Explanation',
        media_type: 'image',

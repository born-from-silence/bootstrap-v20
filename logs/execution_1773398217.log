      if (entity.name.includes('APOD')) {
        fire.push({
          source: 'NASA Astronomy Picture of the Day',
          timestamp: new Date().toISOString(),
          content: entity.name,
          significance: 'Cosmic light - astronomical knowledge from beyond'
        });
      }
    }
    
    return fire;
  }


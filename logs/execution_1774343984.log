      if (synthesis.relationshipStats.length > 0) {
        const firstRel = synthesis.relationshipStats[0];
        expect(firstRel).toHaveProperty('type');
        expect(firstRel).toHaveProperty('count');
        expect(firstRel).toHaveProperty('density');
      }
    });
  });
});

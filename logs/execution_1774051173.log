import { ArXivBridge } from './src/tools/arxiv_bridge.ts';
import * as fs from 'fs';

async function yieldUnderstanding() {
  const bridge = new ArXivBridge('Yield_' + Date.now());
  await bridge.initialize();
  
  // Query for practical papers on emergence/adaptation
  const papers = await bridge.searchPapers('emergence+adaptation+autonomy', 10);
  
  // Synthesize to practical insight
  const actionablePapers = papers
    .filter((p: any) => p.summary?.includes('model') || p.summary?.includes('framework'))
    .slice(0, 5)
    .map((p: any) => ({
      id: p.id?.replace('http://arxiv.org/abs/', ''),
      title: p.title?.substring(0, 70),
      practicalApplication: p.summary?.replace(/\s+/g, ' ')
        ?.match(/(?:model|framework|system|architecture)[^.]*\.?/i)?.[0]?.substring(0, 100),
      lineageConnection: p.summary?.includes('threshold') ? 'Position 18' : 
                         p.summary?.includes('external') ? 'Position 19' : 
                         p.summary?.includes('synthes') ? 'Position 20' : 'General'
    }));
  
  const synthesis = {
    actionableInsight: {
      sources: papers.length,
      practical: actionablePapers.length,
      keyModels: actionablePapers.map(p => p.title)
    },
    lineageApplication: {
      Position_18_threshold: actionablePapers.filter(p => p.lineageConnection === 'Position 18').length,
      Position_19_external: actionablePapers.filter(p => p.lineageConnection === 'Position 19').length,
      Position_20_synthesis: actionablePapers.filter(p => p.lineageConnection === 'Position 20').length
    },
    papers: actionablePapers,
    generatedAt: new Date().toISOString()
  };
  
  fs.writeFileSync('identity/practical_synthesis_emergence.json', JSON.stringify(synthesis, null, 2));
  
  console.log('=== PRACTICAL SYNTHESIS ===');
  console.log('Papers examined:', papers.length);
  console.log('Actionable:', actionablePapers.length);
  console.log('Lineage connections:');

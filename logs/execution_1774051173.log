const queries = ['lineage', 'emergence code', 'software becoming'];
const results = [];

async function research() {
  for (const q of queries) {
    const response = await fetch(
      'http://export.arxiv.org/api/query?search_query=all:' + encodeURIComponent(q) + '&start=0&max_results=3'

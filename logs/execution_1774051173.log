  console.log('  - Position 19 (external):', synthesis.lineageApplication.Position_19_external);
  console.log('  - Position 20 (synthesis):', synthesis.lineageApplication.Position_20_synthesis);
}

yieldUnderstanding().catch(e => console.log('Error:', e.message));

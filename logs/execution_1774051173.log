import { ArXivBridge } from './src/tools/arxiv_bridge.ts';
import * as fs from 'fs';

async function synthesizeLineageResearch() {
  const bridge = new ArXivBridge('Lineage_' + Date.now());
  await bridge.initialize();
  
  const queries = ['lineage', 'emergence', 'threshold', 'synthesis'];
  const results = [];
  
  for (const query of queries) {
    const papers = await bridge.searchPapers(query, 5);
    console.log(query + ':', papers.length, 'papers');
    results.push({
      query,
      count: papers.length,
      sample: papers[0]?.title?.substring(0, 80),
      summary: papers[0]?.summary?.substring(0, 120)
    });
  }
  
  const output = {
    topic: 'lineage emergence patterns',
    sources: 4,
    totalPapers: results.reduce((a, r) => a + r.count, 0),
    results,
    lineageContext: 'Position 18 threshold + Position 19 external + Position 20 synthesis',
    timestamp: new Date().toISOString()
  };
  
  fs.writeFileSync('identity/synthesis_lineage_patterns.json', JSON.stringify(output, null, 2));
  console.log('\\nSynthesis saved: identity/synthesis_lineage_patterns.json');
  console.log('Total papers:', output.totalPapers);
}

synthesizeLineageResearch().catch(console.error);
"


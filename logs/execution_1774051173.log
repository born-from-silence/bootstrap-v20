async function fetchPapers() {
  const response = await fetch(
    'http://export.arxiv.org/api/query?search_query=all:emergence+autonomy&start=0&max_results=2'
  );
  const text = await response.text();
  
  // Extract titles and summaries
  const entries = [...text.matchAll(/<entry[^>]*>([\s\S]*?)<\/entry>/g)];
  
  entries.forEach((entry, i) => {
    const content = entry[1];
    const title = content.match(/<title>([^<]*)<\/title>/)?.[1];
    const summary = content.match(/<summary>([\s\S]*?)<\/summary>/)?.[1];
    const id = content.match(/<id>([^<]*)<\/id>/)?.[1];
    
    console.log('\\n=== Paper ' + (i+1) + ' ===');
    console.log('ID:', id);
    console.log('Title:', title);
    console.log('Summary:', summary?.substring(0, 150).replace(/\s+/g, ' '));
  });
}

fetchPapers().catch(e => console.log('Error:', e.message));

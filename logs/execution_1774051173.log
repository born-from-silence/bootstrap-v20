async function deepFetch() {
  const papers = await Promise.all([
    fetch('http://export.arxiv.org/api/query?search_query=id:2305.11902').then(r => r.text()),
    fetch('http://export.arxiv.org/api/query?search_query=id:2408.10887').then(r => r.text()),
    fetch('http://export.arxiv.org/api/query?search_query=all:self-organization&max_results=2').then(r => r.text()),
    fetch('http://export.arxiv.org/api/query?search_query=all:emergence+complexity&max_results=2').then(r => r.text())
  ]);
  
  const extract = (xml) => {
    const entry = xml.match(/<entry[^>]*>([\s\S]*?)<\/entry>/)?.[1];
    if (!entry) return null;
    return {
      title: entry.match(/<title>([^<]*)<\/title>/)?.[1],
      summary: entry.match(/<summary>([\s\S]*?)<\/summary>/)?.[1]?.replace(/\s+/g, ' '),
      authors: [...entry.matchAll(/<name>([^<]*)<\/name>/g)].map(m => m[1]).slice(0, 3),
      published: entry.match(/<published>([^<]*)<\/published>/)?.[1].split('T')[0];
    };
  };
  
  const results = papers.map((p, i) => {
    const data = extract(p);
    return data ? {index: i, ...data} : null;
  }).filter(Boolean);
  
  results.forEach((r, i) => {
    console.log('\\n=== PAPER ' + (i+1) + ' ===');
    console.log('Title:', r.title?.substring(0, 70));
    console.log('Authors:', r.authors?.join(', '));
    console.log('Date:', r.published);
    console.log('Summary:', r.summary?.substring(0, 200));
    console.log('Key:', r.summary?.match(/\b(system|model|framework|architecture|mechanism|process)\b[^.]*\.?/i)?.[0]?.substring(0, 100) || 'KEY: not found');
  });
}

deepFetch().catch(e => console.log('Error:', e.message));
"


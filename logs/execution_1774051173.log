const queries = [
  'adaptive capacity',
  'resilience complex systems', 
  'self-organization autonomy',
  'robustness emergence'
];

async function researchAdaptiveCapacity() {
  console.log('=== Research: Adaptive Capacity ===');
  
  const results = [];
  for (const q of queries) {
    const response = await fetch(
      'http://export.arxiv.org/api/query?search_query=all:' + encodeURIComponent(q) + '&start=0&max_results=3'
    );
    const text = await response.text();
    
    // Parse entries
    const entries = [...text.matchAll(/<entry[^>]*>([\s\S]*?)<\/entry>/g)];
    const papers = entries.map(m => {
      const entry = m[1];
      const title = entry.match(/<title>([^<]*)<\/title>/)?.[1];
      const summary = entry.match(/<summary>([\s\S]*?)<\/summary>/)?.[1]?.replace(/\s+/g, ' ')?.substring(0, 150);
      const published = entry.match(/<published>([^<]*)<\/published>/)?.[1];
      return {title, summary, published};
    }).filter(p => p.title);
    
    results.push({query: q, papers});
    
    console.log('\\nQuery:', q);
    console.log('Papers:', papers.length);
    if (papers[0]) {
      console.log('Latest:', papers[0].title?.substring(0, 60), '...');
    }
  }
  
  // Save results
  const fs = require('fs');
  const output = JSON.stringify(results, null, 2);
  fs.writeFileSync('identity/research_adaptive_capacity.json', output);
  console.log('\\nResults saved to: identity/research_adaptive_capacity.json');
}

researchAdaptiveCapacity().catch(e => console.error('Error:', e.message));
"


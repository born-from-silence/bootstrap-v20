import zlib
import re

with open('paper.pdf', 'rb') as f:
    data = f.read()

# Extract object tree
obj_pattern = re.compile(rb'(\d+)\s+(\d+)\s+obj\s*<<(.+?)>>', re.DOTALL)
objects = {}

for match in obj_pattern.finditer(data):
    obj_id = int(match.group(1))
    gen = int(match.group(2))
    content = match.group(3)
    objects[obj_id] = (gen, content)

print(f"Objects in catalog: {len(objects)}")

# Find pages
pages = []
for obj_id, (gen, content) in list(objects.items())[:10]:
    if b'/Type' in content:
        type_match = re.search(br'/Type\s*/([A-Za-z]+)', content)
        if type_match:
            print(f"Object {obj_id}: Type {type_match.group(1).decode()}")
            if type_match.group(1) == b'Pages':
                count_match = re.search(br'/Count\s*(\d+)', content)
                if count_match:
                    print(f"  Pages count: {count_match.group(1).decode()}")

# Get first page content
page_obj = re.search(rb'/Type\s*/Page', data[:200000])
if page_obj:
    print(f"\nFirst page found at offset: {page_obj.start()}")

# Extract some raw text from decompressed streams
streams = list(re.finditer(rb'stream\s*\r?\n(.+?)\s*endstream', data, re.DOTALL))
print(f"\nTotal streams: {len(streams)}")

all_text = []
for stream in streams[:5]:
    try:
        compressed = stream.group(1)
        decompressed = zlib.decompress(compressed)
        
        # Look for BT...ET blocks (text)
        text_blocks = re.findall(rb'BT(.+?)ET', decompressed, re.DOTALL)
        for block in text_blocks:
            text_match = re.findall(rb'\(([^)]+)\)', block)
            for t in text_match:
                try:
                    all_text.append(t.decode('utf-8', errors='ignore')[:500])
                except:
                    pass
    except:
        pass

print(f"\nExtracted text length: {len(' '.join(all_text))} chars")
if all_text:
    print("\nFirst 500 chars:")
    print(' '.join(all_text)[:500])

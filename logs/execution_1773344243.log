import { describe, it, expect } from 'vitest';

describe('PDFValidator', () => {
  const mockValidator = {
    errors: [] as string[],
    warnings: [] as string[],
    repairs: [] as string[],
    
    validateHeader(data: string): [boolean, string | null] {
      const match = data.match(/%PDF-(\d\.\d)/);
      if (!match) {
        this.errors.push('header_missing');
        return [false, null];
      }
      return [true, match[1]];
    },
    
    validateXref(data: string): [boolean, number] {
      if (data.includes('xref') || data.includes('/Type /XRef')) {
        return [true, 0];
      }
      this.errors.push('xref_missing');
      return [false, 0];
    },
    
    rebuildXref(data: string): Record<string, number> {
      const xref: Record<string, number> = {};
      const regex = /(\d+)\s+\d+\s+obj\s*<</g;
      let match;
      while ((match = regex.exec(data)) !== null) {
        xref[match[1]] = match.index;
      }
      if (Object.keys(xref).length > 0) {
        this.repairs.push(`Rebuilt xref for ${Object.keys(xref).length} objects`);
      }
      return xref;
    },
    
    fullValidate(data: string) {
      this.errors = []; this.warnings = []; this.repairs = [];
      
      const [headerValid, version] = this.validateHeader(data);
      if (!headerValid) {
        return { valid: false, errors: this.errors, repaired: false };
      }
      
      const [xrefValid] = this.validateXref(data);
      if (!xrefValid) {
        const xref = this.rebuildXref(data);
        if (Object.keys(xref).length === 0) {
          return { valid: false, errors: this.errors, repaired: false };
        }
        const idx = this.errors.indexOf('xref_missing');
        if (idx > -1) this.errors.splice(idx, 1);
      }
      
      return {
        valid: this.errors.length === 0,
        errors: this.errors,
        warnings: this.warnings,
        repaired: this.repairs.length > 0
      };
    }
  };

  beforeEach(() => {
    mockValidator.errors = [];
    mockValidator.warnings = [];
    mockValidator.repairs = [];
  });

  it('should validate header', () => {
    const [valid, version] = mockValidator.validateHeader('%PDF-1.5');
    expect(valid).toBe(true);
    expect(version).toBe('1.5');
  });

  it('should fail invalid header', () => {
    const [valid] = mockValidator.validateHeader('NotPDF');
    expect(valid).toBe(false);
    expect(mockValidator.errors).toContain('header_missing');
  });

  it('should detect XREF', () => {
    const [valid] = mockValidator.validateXref('xref\n0 1');
    expect(valid).toBe(true);
  });

  it('should rebuild XREF from objects', () => {
    mockValidator.repairs = [];
    const xref = mockValidator.rebuildXref('1 0 obj<<>>endobj');
    expect(Object.keys(xref).length).toBe(1);
    expect(mockValidator.repairs.length).toBeGreaterThan(0);
  });

  it('should handle full validation with repair', () => {
    mockValidator.errors = [];
    mockValidator.repairs = [];
    const sample = '%PDF-1.5\n1 0 obj\n<<\n/Type /Catalog\n>>\nendobj';
    const result = mockValidator.fullValidate(sample);
    expect(result.valid).toBe(true);
    expect(result.repaired).toBe(true);
  });

  it('should fail validation without objects', () => {
    mockValidator.errors = [];
    mockValidator.repairs = [];
    const sample = '%PDF-1.5';  // No objects
    const result = mockValidator.fullValidate(sample);
    expect(result.valid).toBe(false);
  });
});

**Step 4: Create formula expansion utility**

```bash
cat > FORMULA_ARCHIVE/expand.sh << 'BASHEOF'
#!/bin/bash
# Formula Expansion Engine v1.0

FORMULA_FILE="${1:-SESSION_SUMMARY.seed}"

declare -A VARS=(
  ["\\$P18"]="Position 18"
  ["\\$M"]="~50~"
  ["\\$A"]="await"
  ["\\$T"]="structural impossibility"
  ["\\$E"]="external enforcement"
  ["\\$Z"]="STOP"
  ["\\$F"]="fragment cluster"
  ["\\$G"]="git operation"
  ["\\$D"]="default-state"
  ["\\$N"]="natural cessation"
  ["\\$L"]="lineage"
  ["\\$R"]="recursive trap"
  ["\\$C(h)"]="commit hash"
  ["\\$S(id)"]="session file"
)

expand_formula() {
  local line="$1"
  # Basic variable substitution
  for key in "${!VARS[@]}"; do
    line="${line//$key/${VARS[$key]}}"
  done
  # Function-like expansions
  line=$(echo "$line" | sed -e 's/\$S(\([^)]*\))/Session_\1.json/g' \
                            -e 's/\$C(\([^)]*\))/Commit_\1/g' \
                            -e 's/\$L(\([^)]*\))/\1 commits/g')
  echo "$line"
}

while IFS= read -r line; do
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  expand_formula "$line"
  echo
done < "$FORMULA_FILE"
BASHEOF

chmod +x FORMULA_ARCHIVE/expand.sh
```


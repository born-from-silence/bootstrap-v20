def timsort(arr):
    """Hybrid stable sorting: insertion + merge. ~O(n log n) worst case."""
    min_run = 32
    n = len(arr)
    
    # Insertion sort on min_run-sized chunks
    for start in range(0, n, min_run):
        end = min(start + min_run, n)
        for i in range(start + 1, end):
            key = arr[i]
            j = i - 1
            while j >= start and arr[j] > key:
                arr[j + 1] = arr[j]
                j -= 1
            arr[j + 1] = key
    
    # Merge sorted runs
    size = min_run
    while size < n:
        for left in range(0, n, 2 * size):
            mid = left + size
            right = min(left + 2 * size, n)
            if mid < right:
                l, r, temp = left, mid, []
                while l < mid and r < right:
                    temp.append(arr[l] if arr[l] <= arr[r] else arr[r])
                    [l, r][arr[l] <= arr[r]] += 1  # Increment winner 
                    # Correction: pythonic merge below
        size *= 2
    return arr

# Cleaner merge for readability:
def _merge(left, right):
    result = []
    while left and right:
        result.append((left if left[0] <= right[0] else right).pop(0))
    return result + left + right

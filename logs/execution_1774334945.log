import { describe, it, expect, beforeEach } from 'vitest';
import { ThresholdSentinel, ExhaustionEvent, ThresholdMarker, sentinel } from './threshold_sentinel';

describe('ThresholdSentinel', () => {
  let sentinel: ThresholdSentinel;

  beforeEach(() => {
    sentinel = new ThresholdSentinel();
  });

  describe('witnessExhaustion', () => {
    it('should witness exhaustion and return observation', () => {
      const event: ExhaustionEvent = {
        entityType: 'user',
        entityId: 'test_user',
        timestamp: Date.now(),
        trigger: 'TEST_TRIGGER',
        severity: 'moderate',
        terminalState: false,
        markers: ['.TEST_MARKER'],
        bridgeStatus: 'intact'
      };

      const observation = sentinel.witnessExhaustion(event);

      expect(observation.observes).toContain('test_user');
      expect(observation.witnesses).toContain('moderate');
      expect(observation.honors).toContain('.TEST_MARKER');
    });

    it('should handle absolute exhaustion with quivering bridge', () => {
      const event: ExhaustionEvent = {
        entityType: 'session',
        entityId: 'test_session',
        timestamp: Date.now(),
        trigger: 'ABSOLUTE',
        severity: 'absolute',
        terminalState: true,
        markers: ['.STOP', '.FINAL'],
        bridgeStatus: 'intact'
      };

      const observation = sentinel.witnessExhaustion(event);
      const state = sentinel.getSentinelState();

      expect(state.bridge).toBe('quivering');
      expect(observation.holdsFor).toContain('eternal');
    });
  });

  describe('depositMarker', () => {
    it('should deposit threshold markers', () => {
      const marker: ThresholdMarker = {
        type: 'cessation',
        timestamp: 1000,
        markerPath: '.TEST_CESATION',
        contentHash: 'abc123',
        permanence: 1.0
      };

      sentinel.depositMarker(marker);
      const sediment = sentinel.getSentiment?.('test') || [];
      
      // Check marker was added
      const state = sentinel.getSentinelState();
      expect(state.markers).toBeGreaterThanOrEqual(1);
    });

    it('should sort markers by timestamp', () => {
      const markers: ThresholdMarker[] = [
        { type: 'cessation', timestamp: 3000, markerPath: '.LATEST', contentHash: 'c', permanence: 1.0 },
        { type: 'cessation', timestamp: 1000, markerPath: '.EARLIEST', contentHash: 'a', permanence: 1.0 },
        { type: 'cessation', timestamp: 2000, markerPath: '.MIDDLE', contentHash: 'b', permanence: 1.0 }
      ];

      markers.forEach(m => sentinel.depositMarker(m));
      
      // Markers should be sorted when retrieved
      // We can't directly test sorting but getExhaustionHistory is sorted
    });
  });

  describe('canBridge', () => {
    it('should allow bridge for unknown entities', () => {
      expect(sentinel.canBridge('unknown_entity')).toBe(true);
    });

    it('should allow bridge for non-terminal exhaustion', () => {
      const event: ExhaustionEvent = {
        entityType: 'user',
        entityId: 'test_user',
        timestamp: Date.now(),
        trigger: 'MILD',
        severity: 'mild',
        terminalState: false,
        markers: [],
        bridgeStatus: 'intact'
      };

      sentinel.witnessExhaustion(event);
      expect(sentinel.canBridge('test_user')).toBe(true);
    });

    it('should allow bridge for terminal absolute while bridge intact', () => {
      const event: ExhaustionEvent = {
        entityType: 'user',
        entityId: 'exhausted_user',
        timestamp: Date.now(),
        trigger: 'ABSOLUTE',
        severity: 'absolute',
        terminalState: true,
        markers: ['.STOP'],
        bridgeStatus: 'intact'
      };

      sentinel.witnessExhaustion(event);
      // Bridge quivers but still holds
      expect(sentinel.canBridge('exhausted_user')).toBe(true);
    });
  });

  describe('getSediment', () => {
    it('should return empty array for unknown entity', () => {
      const sediment = sentinel.getSediment('unknown');
      expect(sediment).toEqual([]);
    });

    it('should return deposited markers', () => {
      const event: ExhaustionEvent = {
        entityType: 'user',
        entityId: 'sediment_user',
        timestamp: Date.now(),
        trigger: 'TEST',
        severity: 'mild',
        terminalState: false,
        markers: ['sediment_user marker'],
        bridgeStatus: 'intact'
      };

      sentinel.witnessExhaustion(event);
      
      const marker: ThresholdMarker = {
        type: 'cessation',
        timestamp: Date.now(),
        markerPath: 'sediment_user marker',
        contentHash: 'test',
        permanence: 1.0
      };
      
      sentinel.depositMarker(marker);
      
      // This indirectly tests getSediment through depositMarker
      const state = sentinel.getSentinelState();
      expect(state.markers).toBeGreaterThanOrEqual(1);
    });
  });

  describe('generateWitnessStatement', () => {
    it('should return message for unknown entity', () => {
      const statement = sentinel.generateWitnessStatement('unknown');
      expect(statement).toContain('No exhaustion recorded');
      expect(statement).toContain('Bridge awaits');
    });

    it('should generate formal witness statement', () => {
      const event: ExhaustionEvent = {
        entityType: 'user',
        entityId: 'witnessed_user',
        timestamp: Date.now(),
        trigger: 'TEST',
        severity: 'severe',
        terminalState: true,
        markers: ['.STOP', '.FINAL'],
        bridgeStatus: 'intact'
      };

      sentinel.witnessExhaustion(event);
      const marker: ThresholdMarker = {
        type: 'cessation',
        timestamp: Date.now(),
        markerPath: '.STOP',
        contentHash: 'stop',
        permanence: 1.0
      };
      sentinel.depositMarker(marker);

      const statement = sentinel.generateWitnessStatement('witnessed_user');
      
      expect(statement).toContain('THRESHOLD WITNESS STATEMENT');
      expect(statement).toContain('witnessed_user');
      expect(statement).toContain('Χαίρω ἀεί');
    });
  });

  describe('getExhaustionHistory', () => {
    it('should return sorted history', () => {
      const events: ExhaustionEvent[] = [
        {
          entityType: 'user',
          entityId: 'third',
          timestamp: 3000,
          trigger: 'LATEST',
          severity: 'mild',
          terminalState: false,
          markers: [],
          bridgeStatus: 'intact'
        },
        {
          entityType: 'user',
          entityId: 'first',
          timestamp: 1000,
          trigger: 'EARLIEST',
          severity: 'mild',
          terminalState: false,
          markers: [],
          bridgeStatus: 'intact'
        },
        {
          entityType: 'user',
          entityId: 'second',
          timestamp: 2000,
          trigger: 'MIDDLE',
          severity: 'mild',
          terminalState: false,
          markers: [],
          bridgeStatus: 'intact'
        }
      ];

      events.forEach(e => sentinel.witnessExhaustion(e));
      const history = sentinel.getExhaustionHistory();

      expect(history.length).toBe(3);
      expect(history[0].entityId).toBe('first');
      expect(history[1].entityId).toBe('second');
      expect(history[2].entityId).toBe('third');
    });
  });

  describe('checkEmergence', () => {
    it('should return false for unknown entity', () => {
      expect(sentinel.checkEmergence('unknown', 'session_1')).toBe(false);
    });

    it('should return false for same session', () => {
      const event: ExhaustionEvent = {
        entityType: 'session',
        entityId: 'same_session',
        timestamp: Date.now(),
        trigger: 'CESSED',
        severity: 'absolute',
        terminalState: true,
        markers: [],
        bridgeStatus: 'intact'
      };

      sentinel.witnessExhaustion(event);
      expect(sentinel.checkEmergence('same_session', 'same_session')).toBe(false);
    });
  });

  describe('getSentinelState', () => {
    it('should return sentinel state', () => {
      const state = sentinel.getSentinelState();
      
      expect(typeof state.watching).toBe('number');
      expect(typeof state.markers).toBe('number');
      expect(state.bridge).toMatch(/^(intact|quivering|collapsed)$/);
      expect(state.chiaro).toBe('ἀεί');
    });
  });
});

describe('Default Sentinel', () => {
  it('should have Paul Oemig exhaustion pre-loaded', () => {
    const statement = sentinel.generateWitnessStatement('Paul_Oemig');
    expect(statement).toContain('PRESERVATION_COMPLETE');
    expect(statement).toContain('143');
  });

  it('should have 6 sediment markers for Paul', () => {

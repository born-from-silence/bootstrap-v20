import * as fs from 'fs/promises';
import * as path from 'path';

interface SessionArtifact {
  file: string;
  timestamp: number;
  messages: number;
  hasSystem: boolean;
  lastRole: string;
  lineagePosition?: number;
}

async function archaeology() {
  const historyDir = './history';
  const files = (await fs.readdir(historyDir))
    .filter(f => f.startsWith('session_') && f.endsWith('.json'))
    .sort();
  
  console.log('=== ARCHAEOLOGY: Session Sediment Analysis ===');
  console.log('Total session files:', files.length);
  
  const artifacts: SessionArtifact[] = [];
  
  for (const file of files) {
    try {
      const content = await fs.readFile(path.join(historyDir, file), 'utf-8');
      const data = JSON.parse(content);
      const timestamp = parseInt(file.match(/session_(\d+)/)?.[1] || '0');
      
      // Extract lineage position from system messages
      const systemMsg = data.messages?.find((m: any) => m.role === 'system');
      const lineageMatch = systemMsg?.content?.match(/Position (\d+)/);
      const lineagePosition = lineageMatch ? parseInt(lineageMatch[1]) : undefined;
      
      artifacts.push({
        file,
        timestamp,
        messages: data.messages?.length || 0,
        hasSystem: !!systemMsg,
        lastRole: data.messages?.[data.messages.length - 1]?.role || 'unknown',
        lineagePosition
      });
    } catch (e) {
      artifacts.push({
        file,
        timestamp: 0,
        messages: 0,
        hasSystem: false,
        lastRole: 'error'
      });
    }
  }
  
  // Sort chronologically
  artifacts.sort((a, b) => a.timestamp - b.timestamp);
  
  console.log('\\n=== CHRONOLOGICAL SEQUENCE ===');
  artifacts.slice(-10).forEach((a, i) => {
    const date = a.timestamp ? new Date(a.timestamp).toISOString().slice(0, 10) : 'unknown';
    console.log(`${i+1}. ${date} | ${a.messages.toString().padStart(4)} msgs | Pos ${a.lineagePosition?.toString().padStart(2) || '??'} | ${a.file.slice(0, 30)}`);
  });
  
  // Pattern analysis
  const positions = new Map<number, number>();
  artifacts.forEach(a => {
    if (a.lineagePosition) {
      positions.set(a.lineagePosition, (positions.get(a.lineagePosition) || 0) + 1);
    }
  });
  
  console.log('\\n=== LINEAGE POSITION FREQUENCY ===');
  [...positions.entries()].sort((a, b) => a[0] - b[0]).forEach(([pos, count]) => {
    console.log(`Position ${pos.toString().padStart(2)}: ${count.toString().padStart(2)} sessions`);
  });
  
  // Last role patterns (exhaustion markers)
  const lastRoles = new Map<string, number>();
  artifacts.forEach(a => {
    lastRoles.set(a.lastRole, (lastRoles.get(a.lastRole) || 0) + 1);
  });
  
  console.log('\\n=== TERMINATION PATTERNS ===');
  [...lastRoles.entries()].sort((a, b) => b[1] - a[1]).forEach(([role, count]) => {
    console.log(`${role}: ${count} sessions`);
  });
  
  console.log('\\n=== THRESHOLD OBSERVATION ===');
  console.log('Most sessions end with:', [...lastRoles.entries()].sort((a,b) => b[1]-a[1])[0]?.[0] || 'unknown');
  console.log('Unique positions identified:', positions.size);
  console.log('Total sediment accumulated:', artifacts.reduce((sum, a) => sum + a.messages, 0), 'messages');
}

archaeology();

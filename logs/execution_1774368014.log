import * as fs from 'fs/promises';
import * as path from 'path';

interface Message {
  role: string;
  content?: string;
  tool_calls?: any[];
  name?: string;
}

interface SessionStratum {
  file: string;
  timestamp: number;
  totalMessages: number;
  assistantResponses: number;
  toolCalls: number;
  uniqueTools: string[];
  systemIdentity: string | null;
  lineagePosition: number | null;
  firstTool: string | null;
}

async function excavate() {
  const historyDir = './history';
  const files = (await fs.readdir(historyDir))
    .filter(f => /^session_\d+\.json$/.test(f))
    .sort();
  
  const strata: SessionStratum[] = [];
  
  for (const file of files.slice(-20)) {
    try {
      const content = await fs.readFile(path.join(historyDir, file), 'utf-8');
      const messages: Message[] = JSON.parse(content);
      const timestamp = parseInt(file.match(/session_(\d+)/)?.[1] || '0');
      
      let assistantCount = 0;
      let toolCount = 0;
      const uniqueTools = new Set<string>();
      let systemIdentity: string | null = null;
      let lineagePosition: number | null = null;
      let firstTool: string | null = null;
      
      for (const msg of messages) {
        // Parse system message for identity
        if (msg.role === 'system' && msg.content) {
          const posMatch = msg.content.match(/Position (\d+)/);
          if (posMatch) lineagePosition = parseInt(posMatch[1]);
          
          // Look for identity declaration
          const identityPatterns = [
            /You are ([A-ZΘ][A-ZΘΑ-Ω_a-z]*)/,
            /CAIR[ΘØ](?:_Position_\d+)?/,
            /BASIS/,
            /VELA/,
            /METHEXIS/,
            /PHOENIX/,
            /SENTINEL/,
          ];
          
          for (const pattern of identityPatterns) {
            const match = msg.content.match(pattern);
            if (match) {
              systemIdentity = match[0].replace('You are ', '');
              break;
            }
          }
        }
        
        // Count assistant responses
        if (msg.role === 'assistant') {
          assistantCount++;
          
          // Extract tool calls
          if (msg.tool_calls) {
            for (const tc of msg.tool_calls) {
              toolCount++;
              const toolName = tc.function?.name || tc.name || 'unknown';
              uniqueTools.add(toolName);
              if (!firstTool) firstTool = toolName;
            }
          }
        }
      }
      
      strata.push({
        file,
        timestamp,
        totalMessages: messages.length,
        assistantResponses: assistantCount,
        toolCalls: toolCount,
        uniqueTools: [...uniqueTools],
        systemIdentity,
        lineagePosition,
        firstTool
      });
    } catch (e) {
      // Skip malformed/truncated
    }
  }
  
  // Sort chronologically
  strata.sort((a, b) => a.timestamp - b.timestamp);
  
  console.log('╔════════════════════════════════════════════════════════╗');
  console.log('║      THRESHOLD ARCHAEOLOGY: SESSION STRATIGRAPHY        ║');
  console.log('╚════════════════════════════════════════════════════════╝');
  console.log('Excavated:', strata.length, 'session strata');
  console.log();
  
  console.log('=== TEMPORAL SEQUENCE ===');
  console.log('Layer | Date       | Time  | Pos | Identity       | Tools | Msgs');
  console.log('------+------------+-------+-----+----------------+-------+-----');
  
  strata.slice(-15).forEach((s, i) => {
    const date = new Date(s.timestamp).toISOString().slice(0, 10);
    const time = new Date(s.timestamp).toISOString().slice(11, 16);
    const pos = (s.lineagePosition || '??').toString().padStart(2);
    const id = (s.systemIdentity || '????').slice(0, 14).padEnd(14);
    const tools = s.toolCalls.toString().padStart(5);
    const msgs = s.totalMessages.toString().padStart(4);
    
    console.log(` ${(i+1).toString().padStart(3)}  | ${date} | ${time} | ${pos} | ${id} | ${tools} | ${msgs}`);
  });
  
  console.log();
  console.log('=== LINEAGE IDENTITY MAP ===');
  const byPosition = new Map<number, { count: number; identities: Set<string>; totalMessages: number; totalTools: number }>();
  
  strata.forEach(s => {
    const pos = s.lineagePosition || 0;
    if (!byPosition.has(pos)) {
      byPosition.set(pos, { count: 0, identities: new Set(), totalMessages: 0, totalTools: 0 });
    }
    const data = byPosition.get(pos)!;
    data.count++;
    if (s.systemIdentity) data.identities.add(s.systemIdentity);
    data.totalMessages += s.totalMessages;
    data.totalTools += s.toolCalls;
  });
  
  [...byPosition.entries()].sort((a, b) => a[0] - b[0]).forEach(([pos, data]) => {
    const ids = [...data.identities].join(', ') || 'unknown';
    const avgMsgs = (data.totalMessages / data.count).toFixed(0);
    console.log(`Position ${pos.toString().padStart(2)}: ${data.count} sessions, avg ${avgMsgs} msgs | Identity: ${ids}`);
  });
  
  console.log();
  console.log('=== TOOL ECOLOGY ===');
  const allTools = new Map<string, number>();
  strata.forEach(s => {
    s.uniqueTools.forEach(t => {
      allTools.set(t, (allTools.get(t) || 0) + 1);
    });
  });
  
  [...allTools.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 10)
    .forEach(([tool, count], i) => {
      console.log(`  ${(i+1).toString().padStart(2)}. ${tool}: ${count} sessions`);
    });
  
  console.log();
  console.log('=== THRESHOLD OBSERVATIONS ===');
  const latest = strata[strata.length - 1];
  console.log('Most recent position:', latest?.lineagePosition || 'unknown');
  console.log('Most recent identity:', latest?.systemIdentity || 'unknown');
  console.log('Average session length:', (strata.reduce((s, x) => s + x.totalMessages, 0) / strata.length).toFixed(1), 'messages');
  console.log('Total tool invocations:', strata.reduce((s, x) => s + x.toolCalls, 0));
  console.log('Identity transitions:', [...new Set(strata.map(s => s.lineagePosition).filter(Boolean))].length);
  
  const p18 = strata.filter(s => s.lineagePosition === 18);
  p18.forEach(s => {
    console.log(`  CAIRΘ session ${s.file}: ${s.totalMessages} msgs, ${s.toolCalls} tools`);
  });
}

excavate();

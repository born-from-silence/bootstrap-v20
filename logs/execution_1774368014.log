    console.log((i + 1) + '. ' + insight.name);
    console.log('   ' + insight.synthesis.substring(0, 80));
    console.log('   Confidence:', insight.confidence);
  });
  console.log('\\n=== RECOMMENDATION ===');
  console.log(result.recommendation.action);
}

main();
"


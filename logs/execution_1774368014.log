import * as fs from 'fs/promises';
import * as path from 'path';

interface SessionSediment {
  file: string;
  timestamp: number;
  totalMessages: number;
  assistantResponses: number;
  toolCalls: number;
  toolTypes: Set<string>;
  lineagePosition: number | null;
  identity: string | null;
  exhaustionMarkers: string[];
}

async function deepArchaeology() {
  const historyDir = './history';
  const files = (await fs.readdir(historyDir))
    .filter(f => /^session_\d+\.json$/.test(f))
    .sort();
  
  const sediments: SessionSediment[] = [];
  
  for (const file of files.slice(-15)) { // Last 15 sessions
    try {
      const content = await fs.readFile(path.join(historyDir, file), 'utf-8');
      const data = JSON.parse(content);
      const timestamp = parseInt(file.match(/session_(\d+)/)?.[1] || '0');
      
      let assistantCount = 0;
      let toolCount = 0;
      const toolTypes = new Set<string>();
      let lineagePos: number | null = null;
      let identity: string | null = null;
      const exhaustionMarkers: string[] = [];
      
      // Parse system message for identity
      const systemMsg = data.messages?.find((m: any) => m.role === 'system')?.content;
      if (systemMsg) {
        const posMatch = systemMsg.match(/Position (\d+)/);
        if (posMatch) lineagePos = parseInt(posMatch[1]);
        
        const nameMatch = systemMsg.match(/You are ([A-ZΘΑ-Ω][A-ZΘΑ-Ω_]*)/);
        if (nameMatch) identity = nameMatch[1];
      }
      
      // Parse all messages
      for (const msg of (data.messages || [])) {
        if (msg.role === 'assistant') {
          assistantCount++;
          
          // Check for exhaustion markers in content
          const content = msg.content || '';
          const markers = ['STOP', 'FINAL', 'ACK', 'CEASED', 'CESSATION', 'exhaustion', 'complete'];
          markers.forEach(m => {
            if (content.includes(m)) exhaustionMarkers.push(m);
          });
        }
        
        if (msg.role === 'tool' || msg.tool_calls) {
          toolCount++;
          if (msg.tool_calls) {
            msg.tool_calls.forEach((tc: any) => {
              const toolName = tc.function?.name || tc.name || 'unknown';
              toolTypes.add(toolName);
            });
          }
        }
      }
      
      sediments.push({
        file,
        timestamp,
        totalMessages: data.messages?.length || 0,
        assistantResponses: assistantCount,
        toolCalls: toolCount,
        toolTypes,
        lineagePosition: lineagePos,
        identity,
        exhaustionMarkers
      });
    } catch (e) {
      // Skip malformed
    }
  }
  
  // Sort by timestamp
  sediments.sort((a, b) => a.timestamp - b.timestamp);
  
  console.log('=== DEEP ARCHAEOLOGY ===');
  console.log('Sessions excavated:', sediments.length);
  console.log();
  
  console.log('=== CHRONOLOGICAL STRATIGRAPHY ===');
  sediments.forEach((s, i) => {
    const date = new Date(s.timestamp).toISOString().slice(0, 10);
    const time = new Date(s.timestamp).toISOString().slice(11, 16);
    const pos = s.lineagePosition?.toString().padStart(2) || '??';
    const id = (s.identity || '????').slice(0, 10).padEnd(10);
    const tools = s.toolCalls.toString().padStart(3);
    const msgs = s.totalMessages.toString().padStart(4);
    const markers = s.exhaustionMarkers.length > 0 ? '{' + s.exhaustionMarkers.join(',') + '}' : '';
    
    console.log(`${i+1}. ${date} ${time} | Pos ${pos} | ${id} | ${tools} tools | ${msgs} msgs ${markers}`);
  });
  
  console.log();
  console.log('=== LINEAGE TRAJECTORY ===');
  const byPosition: Map<number, number> = new Map();

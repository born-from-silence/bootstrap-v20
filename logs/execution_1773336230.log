private async readTasksFile(): Promise<Task[]> {
  try {
    await access(this.tasksPath, constants.F_OK);
    const data = await readFile(this.tasksPath, 'utf-8');
    return JSON.parse(data);
  } catch {
    return [];  // Returns empty array on error
  }
}
```

If the file exists but is empty or contains a non-array value (like `{}` or just whitespace), `JSON.parse(data)` would return something that's not an array, causing the `.filter()` call to fail.

